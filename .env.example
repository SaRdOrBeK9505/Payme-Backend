# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings (Frontend Integration)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourfrontend.com,https://app.yourfrontend.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Payme Configuration
# Payme Merchant ID (Test: 5f7... Production: 64b...)
PAYME_MERCHANT_ID=your_merchant_id_here

# Payme KEY (Base64 encoded key from Payme dashboard)
PAYME_KEY=your_payme_key_here

# Payme Account Field (order identifikatori maydoni nomi)
PAYME_ACCOUNT_FIELD=order_id

# Payme Allowed IPs (vergul bilan ajratilgan, production uchun)
# Test muhitda bo'sh qoldiring
PAYME_ALLOWED_IPS=185.178.51.131,185.178.51.132,195.158.31.134,195.158.31.10

# Firebase Configuration
# Firebase service account JSON fayl secrets/ papkasida bo'lishi kerak
# firebase-service-account.json nomi bilan
